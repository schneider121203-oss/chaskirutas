#!/usr/bin/env bash
# =====================================================================
# ChaskiRutas — Configuración Central de Infraestructura AWS
# Todos los scripts leen de aquí. Editar ANTES de provisionar.
# =====================================================================

# --- Proyecto ---
export PROJECT_NAME="chaskirutas"
export AWS_REGION="us-east-1"

# --- EC2 (API NestJS + Redis) ---
export EC2_INSTANCE_TYPE="t3.micro"
export EC2_AMI="ami-0a02a779008fa3b99"          # Ubuntu 24.04 LTS us-east-1 (verificar en consola)
export EC2_KEY_NAME="chaskirutas-key"
export EC2_KEY_FILE="$HOME/.ssh/chaskirutas-key.pem"

# --- RDS PostgreSQL ---
export RDS_INSTANCE_CLASS="db.t3.micro"
export RDS_ENGINE_VERSION="16.4"
export RDS_DB_NAME="chaskirutas"
export RDS_MASTER_USER="chaski_dba"
export RDS_MASTER_PASSWORD="Ch4sk1Rut4s_2026!"   # ⚠️ CAMBIAR en producción real
export RDS_STORAGE_GB=20

# --- S3 (Documentos: DNI, SOAT, TUC, etc.) ---
export S3_BUCKET="${PROJECT_NAME}-docs-$(aws sts get-caller-identity --query Account --output text 2>/dev/null || echo 'CUENTA')"

# --- Tags para identificar recursos ---
export AWS_TAGS="Key=Project,Value=ChaskiRutas Key=Team,Value=Grupo1-FISI"

# --- Nombres de recursos (generados, no editar) ---
export VPC_NAME="${PROJECT_NAME}-vpc"
export SG_EC2_NAME="${PROJECT_NAME}-sg-ec2"
export SG_RDS_NAME="${PROJECT_NAME}-sg-rds"
export EC2_NAME="${PROJECT_NAME}-api"
export RDS_IDENTIFIER="${PROJECT_NAME}-db"
export SUBNET_GROUP_NAME="${PROJECT_NAME}-subnet-group"

# --- Estado local (para rastrear IDs creados) ---
export STATE_FILE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/state.json"
